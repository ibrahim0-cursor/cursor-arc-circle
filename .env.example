# AI Keys (optional — app runs in heuristic mode without these)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Market Intelligence
NEWS_API_KEY=
COINGECKO_API_KEY=
# GeckoTerminal — free, no key (Alpha scan trending + DexScreener merge)
# Moralis — token metadata (optional)
MORALIS_API_KEY=
# Etherscan / Basescan / Arbiscan — contract verify (optional, same key style per chain)
ETHERSCAN_API_KEY=
# Gold Rush / Covalent (optional — COVALENT_API_KEY or GOLDRUSH_API_KEY)
COVALENT_API_KEY=
GOLDRUSH_API_KEY=
# Twitter scrapers (twikit, nitter, snscrape) are Python/local — not used on Vercel serverless

# Social intelligence — default FREE mode (skips paid LunarCrush/Neynar API calls)
SOCIAL_USE_PREMIUM=false
# LunarCrush — optional; Individual+ subscription (only used if SOCIAL_USE_PREMIUM=true)
LUNARCRUSH_API_KEY=
# LUNARCRUSH_API_BASE=https://lunarcrush.com/api4
# Neynar — Snapchain hub probe always works; cast search needs paid plan + NEYNAR_USE_SEARCH=true
NEYNAR_API_KEY=
# NEYNAR_API_BASE=https://snapchain-api.neynar.com
# NEYNAR_USE_SEARCH=true
# Reddit Data API OAuth — external Next.js app (NOT Devvit/@devvit/reddit) — coming soon
# Create a "script" or "web app" at https://www.reddit.com/prefs/apps
# USER_AGENT format: platform:appid:version (by reddit_username)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:trader-arc:1.0 (by /u/your_reddit_username)

# Birdeye — holders, whales, snipers, live swaps (required for Token intel)
BIRDEYE_API_KEY=
# Alternates also supported: BIRDEYE_KEY, BDS_API_KEY

# Blockchain Infrastructure
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_BASE_RPC=
NEXT_PUBLIC_ALCHEMY_ETH_RPC=

# Swap — 0x API for EVM on-chain quotes
ZEROX_API_KEY=

# Supabase — Agent Memory (new publishable + secret keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# One-time setup: npm run setup:portfolio (Database password from Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=
# Or: SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres
# Run all tables: npm run setup:supabase (needs one of below)
# SUPABASE_ACCESS_TOKEN=   https://supabase.com/dashboard/account/tokens
# SUPABASE_DB_PASSWORD=    Project → Settings → Database
# SUPABASE_PROJECT_REF=pjtkiktpdvhghkqwqpok
# Legacy JWT keys (optional fallback)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Circle Developer Platform (sandbox/test) — optional per-user agent wallets
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_KIT_KEY=
CIRCLE_API_BASE=https://api-sandbox.circle.com/v1/w3s

# Agent vault — shared treasury for Autopilot deposits (Arc Testnet)
NEXT_PUBLIC_AGENT_VAULT_ADDRESS=0x11c1695A3AC5EF9d0B92572f0730F7AC3C87A715
# Or derive vault from server key (address = public key of this key)
ARC_AGENT_PRIVATE_KEY=

# Arc Testnet — USDC-native fees (Circle Agora hackathon)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_AGENT_PRIVATE_KEY=
